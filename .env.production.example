# ============================================================================
# MAU cau hinh PRODUCTION. Copy thanh .env.production va dien gia tri THAT.
#   cp .env.production.example .env.production
# TUYET DOI khong commit .env.production len GitHub (da co trong .gitignore).
# ============================================================================

# --- Ten mien + HTTPS ---
# Ten mien tro ve IP cua VPS (vi du: xphc.yenxuan.gov.vn). BAT BUOC de Caddy cap SSL.
DOMAIN=xphc.diaphuong.gov.vn
# Email nhan thong bao gia han chung chi Let's Encrypt
TLS_EMAIL=quantri@diaphuong.gov.vn

# --- Bao mat ---
# Sinh chuoi ngau nhien 64 ky tu:  openssl rand -hex 32
SECRET_KEY=THAY_BANG_CHUOI_NGAU_NHIEN_openssl_rand_hex_32

# --- Mat khau database (dat manh, khac nhau) ---
POSTGRES_PASSWORD=THAY_MAT_KHAU_POSTGRES_MANH
APP_DB_PASSWORD=THAY_MAT_KHAU_APP_ROLE_MANH

# --- Tuy chon: thoi han token, gioi han upload ---
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_UPLOAD_SIZE_MB=25

# --- White-label: doi cho tung don vi/xa ---
TEN_DON_VI=Phần mềm quản lý XPHC
TEN_DIA_PHUONG=Xã ...
TEN_CO_QUAN_CHU_QUAN=Ủy ban nhân dân xã ...
MO_TA_DON_VI=Hệ thống quản lý xử lý vi phạm hành chính, trật tự xây dựng, đất đai.
# Toa do trung tam ban do mac dinh (lay theo dia phuong)
BAN_DO_VI_DO_MAC_DINH=21.0278
BAN_DO_KINH_DO_MAC_DINH=105.8342
BAN_DO_ZOOM_MAC_DINH=13
