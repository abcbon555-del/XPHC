# development | production - o production se tat Swagger docs va bat buoc SECRET_KEY manh
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://xphc_app_role:change_me@localhost:5432/xphc_db
# Tao SECRET_KEY ngau nhien truoc khi trien khai that: openssl rand -hex 32
SECRET_KEY=change_this_to_a_random_secret_string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
STORAGE_DIR=./storage
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_SIZE_MB=25

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=5

# ===== Cau hinh white-label - doi cac gia tri sau cho tung don vi/khach hang khi ban/trien khai =====
TEN_DON_VI=Phần mềm quản lý XPHC
TEN_DIA_PHUONG=Xã Yên Xuân
TEN_CO_QUAN_CHU_QUAN=Ủy ban nhân dân xã Yên Xuân
MO_TA_DON_VI=Hệ thống quản lý xử lý vi phạm hành chính, trật tự xây dựng, đất đai. Bản đồ số, hồ sơ điện tử, phân quyền theo tài khoản và nhật ký hệ thống minh bạch.
BAN_DO_VI_DO_MAC_DINH=21.0278
BAN_DO_KINH_DO_MAC_DINH=105.8342
BAN_DO_ZOOM_MAC_DINH=13
LOGO_URL=
